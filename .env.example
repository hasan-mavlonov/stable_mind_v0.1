# ============================================================
# MindForm — environment configuration
# Copy to `.env` and fill in your keys. Never commit `.env`.
# ============================================================

# --- Gemma / Google AI ecosystem -----------------------------
# MindForm runs on Google's Gemma open models, served through
# the Gemini API (Google AI Studio).
# Create a key: https://aistudio.google.com/apikey
#
# GEMMA_API_KEY is the primary key MindForm looks for.
# GOOGLE_API_KEY / GOOGLE_AI_STUDIO_KEY are accepted fallbacks.
GEMMA_API_KEY=
GOOGLE_API_KEY=
GOOGLE_AI_STUDIO_KEY=

# --- Model selection -----------------------------------------
# Any Gemma model available on the Gemini API. Defaults to
# gemma-3-27b-it. Per-engine overrides are optional.
MINDFORM_MODEL=gemini-2.5-pro
TALK_MODEL=gemini-2.5-pro
PERCEPTION_MODEL=gemini-2.5-pro
# --- Django --------------------------------------------------
# Generate a key for production. A safe default is used if unset.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
