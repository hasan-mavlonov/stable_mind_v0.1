# ============================================================
# MindForm — environment configuration
# Copy to `.env` and fill in your keys. Never commit `.env`.
# ============================================================

# --- Gemma / Google AI ecosystem -----------------------------
# MindForm runs on Google's Gemma open models, served through
# the Gemini API (Google AI Studio).
# Create a key: https://aistudio.google.com/apikey
#
# GEMMA_API_KEY is the primary key MindForm looks for.
# GOOGLE_API_KEY / GOOGLE_AI_STUDIO_KEY are accepted fallbacks.
GEMMA_API_KEY=
GOOGLE_API_KEY=
GOOGLE_AI_STUDIO_KEY=

# --- Model selection -----------------------------------------
# Any Google model available on the Gemini API. Defaults to
# gemini-2.5-flash-lite — Google's lowest-latency model and the
# fastest choice for MindForm's short calls. For more nuanced
# wording you can raise TALK_MODEL to gemini-2.5-flash; avoid
# gemini-2.5-pro unless you accept several extra seconds per turn.
MINDFORM_MODEL=gemma-4-31b-it
TALK_MODEL=gemma-4-31b-it
PERCEPTION_MODEL=gemma-4-31b-it
# --- Django --------------------------------------------------
# Generate a key for production. A safe default is used if unset.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
